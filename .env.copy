# ==========================================
# AI Chat Gateway - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# ===== 数据库 =====
MYSQL_PASSWORD=your_mysql_password

# ===== Redis =====
SPRING_DATA_REDIS_HOST=localhost

# ===== PgVector (RAG向量数据库) =====
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5433
PGVECTOR_PASSWORD=your_pgvector_password

# ===== AI模型API密钥 (至少配置一个) =====
# OpenAI
OPENAI_API_KEY=sk-xxx

# 通义千问 (DashScope) - 同时用于Embedding
DASHSCOPE_API_KEY=sk-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-12345
ANTHROPIC_BASE_URL=http://38.110.228.225:4000
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6

# ===== RAG Rerank =====
RERANK_API_KEY=your_rerank_api_key
RERANK_BASE_URL=https://api.cohere.ai
RERANK_MODEL=rerank-english-v2.0

# ===== Agent工具 =====
# Serper API (联网搜索) - https://serper.dev 免费注册
SERPER_API_KEY=your_serper_api_key

# LLM总结工具使用的模型
LLM_SUMMARIZE_MODEL=deepseek-chat

# 工作流文件输出目录
FILE_WRITER_OUTPUT_DIR=./workflow-output
