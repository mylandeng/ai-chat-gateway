# ==========================================
# AI Chat Gateway - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# ===== 数据库 =====
MYSQL_PASSWORD=your_mysql_password

# ===== Redis =====
SPRING_DATA_REDIS_HOST=localhost

# ===== PgVector (RAG向量数据库) =====
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5433
PGVECTOR_PASSWORD=your_pgvector_password

# ===== AI模型API密钥 (至少配置一个) =====
# OpenAI
OPENAI_API_KEY=sk-xxx

# 通义千问 (DashScope) - 同时用于Embedding
DASHSCOPE_API_KEY=sk-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6

# ===== 阿里云百炼 (RAG知识库) =====
# 阿里云 AK/SK — 用于百炼平台鉴权
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# 检索提供商: local(本地pgvector) | bailian(阿里云百炼)
RAG_RETRIEVAL_PROVIDER=local

# 百炼工作空间 & 索引
RAG_BAILIAN_WORKSPACE_ID=your_workspace_id
RAG_BAILIAN_INDEX_ID=your_index_id
RAG_BAILIAN_ENDPOINT=bailian.cn-beijing.aliyuncs.com

# 百炼检索参数 (含默认值，可按需调整)
RAG_BAILIAN_DENSE_TOP_K=30
RAG_BAILIAN_SPARSE_TOP_K=30
RAG_BAILIAN_ENABLE_RERANKING=true
RAG_BAILIAN_ENABLE_REWRITE=false
RAG_BAILIAN_RERANK_TOP_N=8
RAG_BAILIAN_RERANK_MIN_SCORE=0.2
RAG_BAILIAN_RERANK_MODEL=qwen3-rerank-hybrid

# ===== DashScope 长期记忆 (Memory API) =====
DASHSCOPE_MEMORY_ENABLED=false
DASHSCOPE_MEMORY_LIBRARY_ID=
DASHSCOPE_MEMORY_PROFILE_SCHEMA_IDS=
DASHSCOPE_MEMORY_PROFILE_WRITE_SCHEMA_ID=

# ===== RAG Rerank (通用) =====
RERANK_API_KEY=your_rerank_api_key
RERANK_BASE_URL=https://api.cohere.ai
RERANK_MODEL=rerank-english-v2.0

# ===== 支付宝AI收 =====
# AI收无沙箱环境，必须使用入驻后的真实配置
# 商户入驻: https://b.alipay.com/page/home/open-ai-pay
# 接入指南: https://ideservice.alipay.com/cms/site/0jaqax

# 应用私钥 (JAVA 使用 PKCS#8 格式，openssl pkcs8 -topk8 转换)
ALIPAY_APP_PRIVATE_KEY=your_pkcs8_private_key
# 支付宝公钥 (上传应用公钥后支付宝返回)
ALIPAY_PUBLIC_KEY=your_alipay_public_key
# 应用 ID (开放平台 → 我的应用 → APPID)
ALIPAY_APP_ID=your_app_id
# AI收服务 ID (入驻 AI收 后分配)
ALIPAY_SERVICE_ID=your_service_id
# 收款金额 (元, 字符串格式)
ALIPAY_AMOUNT=0.01
# 支付截止时间 (分钟)
ALIPAY_PAY_BEFORE_MINUTES=30

# ===== MCP 服务 (百炼 MCP 市场) =====
# 百炼 MCP 服务端点地址
MCP_SERVER_URL=https://dashscope.aliyuncs.com/api/v1/mcps/alipay-ty/sse
# MCP 鉴权方式: aliyun_aksk | aliyun_app | bearer | none
MCP_AUTH_MODE=bearer
# Bearer Token / AppKey 认证 (留空则复用 DASHSCOPE_API_KEY)
MCP_API_KEY=

# ===== Agent工具 =====
# Serper API (联网搜索) - https://serper.dev 免费注册
SERPER_API_KEY=your_serper_api_key

# LLM总结工具使用的模型
LLM_SUMMARIZE_MODEL=deepseek-chat

# 工作流文件输出目录
FILE_WRITER_OUTPUT_DIR=./workflow-output
